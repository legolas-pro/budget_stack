# ============================================================================
# n8n Stack Unificada - Variáveis de Ambiente
# Stack: n8n-stack.yaml (N8N Production Stack v4.0 - Cloudflared)
# ============================================================================
# Copie este arquivo para n8n-stack.env e preencha os valores
# Uso: docker stack deploy -c n8n-stack.yaml n8n --env-file n8n-stack.env
# ============================================================================

# ============================================================================
# IDENTIFICADOR DA STACK (prefixo dos volumes externos)
# ============================================================================
STACK_PREFIX=n8n

# ============================================================================
# PORTAS EXPOSTAS NO HOST
# ATENÇÃO: cada stack na mesma máquina deve usar portas únicas!
# O Cloudflared deve apontar para estes endereços
# Editor:  http://10.1.0.x:N8N_EDITOR_PORT
# Webhook: http://10.1.0.x:N8N_WEBHOOK_PORT
# ============================================================================
N8N_EDITOR_PORT=5678
N8N_WEBHOOK_PORT=5679

# ============================================================================
# PORTAS EXTERNAS DOS SERVIÇOS DE INFRA
# ATENÇÃO: cada stack na mesma máquina deve usar portas únicas!
# Exemplo para 2ª instância: POSTGRES_PORT_EXTERNAL=5433, REDIS_PORT_EXTERNAL=6380
# ============================================================================
POSTGRES_PORT_EXTERNAL=5432
REDIS_PORT_EXTERNAL=6379

# ============================================================================
# BANCO DE DADOS
# ============================================================================
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=n8n_queue

# ============================================================================
# REDIS
# ============================================================================
# DB index do Redis (use valores diferentes se compartilhar o mesmo Redis)
# Clinicia usava DB=3, Din-tools usava DB=1
REDIS_DB=1

# ============================================================================
# N8N - CONFIGURAÇÕES PRINCIPAIS
# ============================================================================
# Imagem do N8N (deixe vazio para usar n8nio/n8n:latest)
N8N_IMAGE=n8nio/n8n:latest

# Chave de criptografia - GERE UMA CHAVE ÚNICA E SEGURA
# Exemplo: openssl rand -hex 32
# IMPORTANTE: use a mesma chave da instância que está migrando!
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_SECURE_KEY

# Hosts/URLs (configure no Cloudflare Tunnel)
N8N_HOST=njs.exemplo.com
WEBHOOK_HOST=wh.exemplo.com

# ============================================================================
# SMTP - CONFIGURAÇÃO DE E-MAIL
# ============================================================================
SMTP_SENDER=bot@exemplo.com
SMTP_USER=bot@exemplo.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=465

# ============================================================================
# INTEGRAÇÕES / IA
# ============================================================================
OPENAI_API_KEY=sk-CHANGE_ME_OPENAI_KEY
