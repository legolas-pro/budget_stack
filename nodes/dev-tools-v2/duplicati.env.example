# ============================================================================
# DUPLICATI - Configurações de Ambiente
# ============================================================================
# Copie este arquivo para duplicati.env e preencha os valores
# Uso: docker stack deploy -c duplicati.yaml duplicati --env-file duplicati.env
# ============================================================================

# ===== STACK =====
STACK_PREFIX=duplicati

# ===== REDE EXTERNA =====
# Nome da rede overlay existente no Swarm à qual o container será conectado
# Exemplo: cloudflared_network, bridge_network, overlay_public
NETWORK_NAME=cloudflared_network

# ===== PORTA =====
DUPLICATI_PORT=8200

# ===== USUÁRIO DO SISTEMA =====
# Execute 'id' no host para obter os valores corretos
PUID=1000
PGID=1000

# ===== LOCALIZAÇÃO =====
TZ=America/Sao_Paulo

# ===== SEGURANÇA =====
# Mínimo 8 caracteres alfanuméricos — criptografa o banco de settings
SETTINGS_ENCRYPTION_KEY=mude_esta_chave_aqui
# Senha de acesso à interface web (padrão linuxserver: "changeme")
WEBSERVICE_PASSWORD=mude_esta_senha_aqui

# ===== FONTES DE BACKUP (somente leitura) =====
# YAMLs de todos os serviços (stacks do Swarm)
STACKS_PATH=/home/familia/stacks

# Dados persistentes dos containers (docker named volumes)
# Não inclui overlay2 (layers de imagem) — só os volumes com dados reais
DOCKER_VOLUMES_PATH=/var/lib/docker/volumes

# Dados do disco grande (HDD)
HDD_PATH=/mnt/dados_hdd

# ===== CLI (opcional) =====
# Argumentos extras passados ao iniciar o Duplicati
CLI_ARGS=

# ============================================================================
# GOOGLE DRIVE — configuração via interface web
# ============================================================================
# Não há variáveis de ambiente para o Google Drive.
# Após subir o container, acesse http://<host>:8200 e:
#   1. Add backup → Next
#   2. Storage type: Google Drive
#   3. AuthID: clique em "AuthID" para iniciar o OAuth no browser
#   4. Destination path: /duplicati/<nome-do-host>
#   5. Source: /source/nvme e /source/hdd (conforme necessário)
# ============================================================================
