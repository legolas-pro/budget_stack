# ============================================================================
# TINY TINY RSS - Configurações de Ambiente
# ============================================================================
# Copie este arquivo para tiny-rss.env e preencha os valores
# Uso: docker stack deploy -c tiny-rss.yaml tiny-rss --env-file tiny-rss.env
# ============================================================================

# ===== STACK =====
STACK_PREFIX=tiny-rss

# ===== REDE EXTERNA =====
# Nome da rede overlay existente no Swarm à qual o nginx será conectado
NETWORK_NAME=cloudflared_network

# ===== IMAGENS =====
TTRSS_IMAGE=supahgreg/tt-rss:latest
TTRSS_NGINX_IMAGE=supahgreg/tt-rss-web-nginx:latest
POSTGRES_IMAGE=postgres:17-alpine

# ===== PORTA =====
# O cloudflared aponta diretamente para esta porta
TTRSS_PORT=8280

# ===== USUÁRIO DO SISTEMA =====
PUID=1000
PGID=1000

# ===== LOCALIZAÇÃO =====
TZ=America/Sao_Paulo

# ===== BANCO DE DADOS =====
TTRSS_DB_USER=postgres
TTRSS_DB_PASS=mude_esta_senha_aqui
TTRSS_DB_NAME=postgres

# ===== ADMIN =====
# Senha do usuário admin (se vazio, uma senha aleatória é gerada — ver logs do app)
ADMIN_USER_PASS=mude_esta_senha_aqui
# 10 = admin | 0 = usuário padrão | -1 = readonly | -2 = bloqueado
ADMIN_USER_ACCESS_LEVEL=10

# ===== PHP-FPM (opcional) =====
PHP_WORKER_MAX_CHILDREN=5
PHP_WORKER_MEMORY_LIMIT=256M

# ============================================================================
# DEPLOY
# ============================================================================
# O volume é criado automaticamente pelo Swarm no primeiro deploy.
#
#   docker stack deploy -c tiny-rss.yaml tiny-rss --env-file tiny-rss.env
#
# Acesso:
#   http://localhost:8280  (acesso direto no host)
#   ou via tunnel cloudflared configurado para localhost:8280
# ============================================================================
