# ============================================================================
# LOBEHUB - Configurações de Ambiente
# ============================================================================
# Copie este arquivo para lobehub.env e preencha os valores
# Uso: docker stack deploy -c lobehub.yaml lobehub --env-file lobehub.env
# ============================================================================

# ===== STACK =====
STACK_PREFIX=lobehub

# ===== REDE EXTERNA =====
# Nome da rede overlay existente no Swarm à qual o app LobeHub será conectado
# Exemplo: cloudflared_network, bridge_network, overlay_public
NETWORK_NAME=cloudflared_network

# ===== IMAGENS =====
LOBE_IMAGE=lobehub/lobehub:latest
POSTGRES_IMAGE=paradedb/paradedb:latest-pg17
REDIS_IMAGE=redis:7-alpine
RUSTFS_IMAGE=rustfs/rustfs:latest
RUSTFS_MC_IMAGE=minio/mc:latest
SEARXNG_IMAGE=searxng/searxng:latest

# ===== PORTAS =====
# Porta da aplicação LobeHub
LOBE_PORT=3210
# RustFS API (S3 compatível)
RUSTFS_PORT=9000
# RustFS Console de administração
RUSTFS_CONSOLE_PORT=9001

# ===== LOCALIZAÇÃO =====
TZ=America/Sao_Paulo

# ===== URLS =====
# URL pública do LobeHub (domínio final)
APP_URL=https://lobe.exemplo.com
# Opcional: URL interna para tráfego server-to-server
INTERNAL_APP_URL=http://lobe:3210

# ===== SEGREDOS =====
# Gerar com: openssl rand -hex 32
KEY_VAULTS_SECRET=mude_esta_chave_aqui
AUTH_SECRET=mude_esta_chave_aqui

# Opcional: chave JWKS (JSON em linha única)
# Deixe vazio se não estiver usando chave customizada
JWKS_KEY=

# Habilita OIDC para conexão do LobeHub Desktop (padrão: 1 = habilitado)
# Requer JWKS_KEY configurada
ENABLE_OIDC=1

# ===== LANGFUSE (OPCIONAL) =====
# Tracing/observabilidade das conversas no Langfuse
# Habilitar: defina ENABLE_LANGFUSE=1 e preencha as chaves abaixo
ENABLE_LANGFUSE=
# Chave secreta do projeto (sk-lf-...)
LANGFUSE_SECRET_KEY=
# Chave pública do projeto (pk-lf-...)
LANGFUSE_PUBLIC_KEY=
# URL do Langfuse (cloud ou self-hosted)
LANGFUSE_HOST=https://cloud.langfuse.com

# ===== INTEGRACOES (OPCIONAL) =====
# Upstash QStash (remove warning de workflow quando definido)
QSTASH_TOKEN=
# Endpoint da sua região (opcional; deixe vazio para padrão)
QSTASH_URL=

# ===== POSTGRES =====
LOBE_DB_NAME=lobechat
POSTGRES_PASSWORD=mude_esta_senha_aqui

# ===== RUSTFS (S3 compatível) =====
RUSTFS_ACCESS_KEY=admin
RUSTFS_SECRET_KEY=mude_esta_senha_aqui
RUSTFS_LOBE_BUCKET=lobe
# Endpoint interno (não use localhost aqui)
S3_ENDPOINT=http://rustfs:9000

# ===== REDIS =====
REDIS_PREFIX=lobechat

# ===== BUSCA WEB (SEARXNG) =====
SEARXNG_URL=http://searxng:8080

# ============================================================================
# DEPLOY
# ============================================================================
# 1. Copie para lobehub.env e preencha os segredos
# 2. Deploy:
#      docker stack deploy -c lobehub.yaml lobehub --env-file lobehub.env
# 3. Aponte o cloudflared para:
#      http://localhost:3210  (ou valor de LOBE_PORT)
# ============================================================================
