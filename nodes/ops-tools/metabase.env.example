# ============================================================================
# METABASE - Configurações de Ambiente
# ============================================================================
# Copie este arquivo para metabase.env e preencha os valores
# Uso: docker stack deploy -c metabase.yaml metabase --env-file metabase.env
# ============================================================================

# ===== STACK =====
STACK_PREFIX=metabase

# ===== REDE EXTERNA =====
# Nome da rede overlay existente no Swarm à qual o Metabase será conectado
# Exemplo: cloudflared_network, bridge_network, overlay_public
NETWORK_NAME=cloudflared_network

# ===== IMAGENS =====
METABASE_IMAGE=metabase/metabase:latest
POSTGRES_IMAGE=postgres:16-alpine
# Imagem local (buildar antes do deploy — ver instruções no bloco DEPLOY abaixo)
MCP_IMAGE=metabase-mcp:local

# ===== PORTAS =====
# Metabase UI (acesso via browser)
METABASE_PORT=3000
# Metabase MCP (acesso interno/API)
METABASE_MCP_PORT=3333

# ===== LOCALIZAÇÃO =====
TZ=America/Sao_Paulo

# ===== METABASE =====
# URL pública usada pelo Metabase para gerar links
# Exemplo: https://dashs.exemplo.com
MB_SITE_URL=https://dashs.exemplo.com

# Chave para criptografia de segredos no Metabase (obrigatória em produção)
# Gerar com: openssl rand -hex 32
MB_ENCRYPTION_SECRET_KEY=mude_esta_chave_aqui

# ===== BANCO DE DADOS (PostgreSQL do app Metabase) =====
MB_DB_NAME=metabaseappdb
MB_DB_USER=metabase
MB_DB_PASS=mude_esta_senha_aqui

# ===== SQLITE BI (espelho do Actual) - OPCIONAL =====
# Usado somente quando fizer deploy com:
#   -c metabase.actual-sqlite.yaml
# Volume externo criado na stack "actual" (ACTUAL_BI_VOLUME_NAME)
ACTUAL_BI_VOLUME_NAME=actual_bi_data
# Caminho de montagem dentro do container do Metabase
METABASE_ACTUAL_BI_MOUNT_PATH=/bi
# Caminho final do arquivo para configurar no driver SQLite do Metabase
METABASE_ACTUAL_BI_DB_FILE=/bi/actual_bi.sqlite

# ===== METABASE MCP (opcional) =====
# URL interna do Metabase acessada pelo MCP (padrão: http://metabase:3000)
# Altere somente se mudar a porta ou o nome do serviço no yaml
METABASE_INTERNAL_URL=http://metabase:3000

# OBRIGATÓRIO para o MCP funcionar: preencha API key OU usuário+senha
# Sem credenciais o serviço sobe mas falha silenciosamente em todas as chamadas
# Opção 1 — API key (preferencial; crie em Metabase > Admin > API Keys)
METABASE_API_KEY=
# Opção 2 — usuário+senha de um admin do Metabase
METABASE_USERNAME=
METABASE_PASSWORD=

MCP_LOG_LEVEL=info

# ============================================================================
# DEPLOY
# ============================================================================
# 1. Copie para metabase.env e preencha os segredos
# 2. Build da imagem MCP (obrigatório antes do primeiro deploy e após atualizações):
#      docker build -t metabase-mcp:local nodes/ops-tools/metabase-mcp/
# 3. Deploy base:
#      docker stack deploy -c metabase.yaml metabase --env-file metabase.env
# 4. Deploy com SQLite do Actual (opcional):
#      docker stack deploy -c metabase.yaml -c metabase.actual-sqlite.yaml metabase --env-file metabase.env
# 5. Aponte o cloudflared para:
#      http://localhost:3000  (ou valor de METABASE_PORT)
# 6. No Metabase (driver SQLite), usar o caminho:
#      ${METABASE_ACTUAL_BI_DB_FILE}
# ============================================================================
