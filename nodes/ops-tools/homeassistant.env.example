# ============================================================================
# HOME ASSISTANT - Configurações de Ambiente
# ============================================================================
# Copie este arquivo para homeassistant.env e preencha os valores
# Uso: docker stack deploy -c homeassistant.yaml homeassistant --env-file homeassistant.env
# ============================================================================

# ===== STACK =====
STACK_PREFIX=homeassistant

# ===== REDE EXTERNA =====
# Nome da rede overlay existente no Swarm à qual o container será conectado
# Exemplo: cloudflared_network, bridge_network, overlay_public
NETWORK_NAME=cloudflared_network

# ===== IMAGEM =====
# Altere a tag para fixar uma versão específica (ex: 2025.2.0)
HA_IMAGE=ghcr.io/home-assistant/home-assistant:stable

# ===== PORTA =====
# O cloudflared aponta diretamente para esta porta
HA_PORT=8123

# ===== LOCALIZAÇÃO =====
TZ=America/Sao_Paulo

# ============================================================================
# DEPLOY
# ============================================================================
# 1. Criar a config via Portainer > Configs > Add config:
#      Nome:     homeassistant_config
#      Conteúdo: copiar o conteúdo de homeassistant_configuration.yaml
#
# 2. Fazer o deploy (volume criado automaticamente):
#      docker stack deploy -c homeassistant.yaml homeassistant --env-file homeassistant.env
#
# 3. Acesso:
#      http://localhost:8123  (acesso direto no host)
#      ou via tunnel cloudflared configurado para localhost:8123
#
# ATENÇÃO: Docker configs são somente leitura — o editor de configuração
# da UI do HA não conseguirá salvar alterações em configuration.yaml.
# Para atualizar, edite a config no Portainer e faça redeploy da stack.
# ============================================================================
