# ============================================================================
# LibreChat Stack — Variáveis de Ambiente
# Stack: librechat-stack.yaml (v1.0 — Cloudflared, sem Traefik/Caddy)
# ============================================================================
# Copie este arquivo: cp librechat-stack.env.example librechat-stack.env
# Preencha TODOS os valores marcados com CHANGE_ME antes de fazer o deploy.
#
# Deploy:
#   docker stack deploy -c librechat-stack.yaml librechat \
#     --env-file librechat-stack.env
# ============================================================================

# ============================================================================
# IDENTIFICADOR DA STACK (prefixo dos volumes externos)
# ============================================================================
STACK_PREFIX=librechat

# ============================================================================
# REDE COMPARTILHADA COM CLOUDFLARED
# Nome da rede overlay onde o cloudflared está conectado.
# ============================================================================
PROXY_NETWORK=proxy_network

# ============================================================================
# PORTAS NO HOST (range 3000 está ocupado — use 4000+)
# ============================================================================
LIBRECHAT_PORT=4080
SUPERGATEWAY_PORT=4001
SWAGGER_MCP_PORT=4003

# ============================================================================
# LIBRECHAT — Chaves de Segurança
# Gere valores únicos com os comandos abaixo:
#   JWT_SECRET:          openssl rand -hex 32
#   JWT_REFRESH_SECRET:  openssl rand -hex 32
#   CREDS_KEY:           openssl rand -hex 32
#   CREDS_IV:            openssl rand -hex 16
# ============================================================================
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32
CREDS_KEY=CHANGE_ME_openssl_rand_hex_32
CREDS_IV=CHANGE_ME_openssl_rand_hex_16

# ============================================================================
# LIBRECHAT — Configurações de Acesso
# ============================================================================
# Banco de dados MongoDB (nome do banco)
MONGO_DB=librechat

# Permitir login por e-mail e registro de novos usuários
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true

# ============================================================================
# MEILISEARCH — Chave mestra
# Gere com: openssl rand -hex 32
# ============================================================================
MEILI_MASTER_KEY=CHANGE_ME_openssl_rand_hex_32

# ============================================================================
# VECTORDB + RAG — desativados (descomentar ao ativar)
# ============================================================================
# VECTORDB_USER=pguser
# VECTORDB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# VECTORDB_NAME=librechat_rag
# EMBEDDINGS_PROVIDER=openai

# ============================================================================
# APIs DE IA
# Chaves injetadas no librechat.yaml via ${VAR} — usadas nos endpoints Groq e DeepSeek.
# ============================================================================
GROQ_API_KEY=CHANGE_ME_GROQ_API_KEY
DEEPSEEK_API_KEY=CHANGE_ME_DEEPSEEK_API_KEY
OPENROUTER_API_KEY=CHANGE_ME_OPENROUTER_API_KEY

# ============================================================================
# SUPERGATEWAY — servidor MCP stdio encapsulado como SSE
# LibreChat conecta via nome do serviço: http://supergateway:8080/sse
# SUPERGATEWAY_MCP_COMMAND: comando stdio que o supergateway vai encapsular
# ============================================================================
SUPERGATEWAY_MCP_COMMAND=npx -y @modelcontextprotocol/server-everything

# ============================================================================
# swagger_mcp — expõe uma API OpenAPI/Swagger como MCP via SSE
# SWAGGER_MCP_SPEC_URL: URL do swagger.json acessível a partir do container
# ============================================================================
SWAGGER_MCP_SPEC_URL=http://192.168.68.115:5007/api-docs/swagger.json