# ============================================================================
# LibreChat Stack — Variáveis de Ambiente
# Stack: librechat-stack.yaml (v1.0 — Cloudflared, sem Traefik/Caddy)
# ============================================================================
# Copie este arquivo: cp librechat-stack.env.example librechat-stack.env
# Preencha TODOS os valores marcados com CHANGE_ME antes de fazer o deploy.
#
# Deploy:
#   docker stack deploy -c librechat-stack.yaml librechat \
#     --env-file librechat-stack.env
# ============================================================================

# ============================================================================
# IDENTIFICADOR DA STACK (prefixo dos volumes externos)
# ============================================================================
STACK_PREFIX=librechat

# ============================================================================
# REDE COMPARTILHADA COM CLOUDFLARED
# Nome da rede overlay onde o cloudflared está conectado.
# ============================================================================
PROXY_NETWORK=proxy_network

# ============================================================================
# PORTAS NO HOST (range 3000 está ocupado — use 4000+)
# O Cloudflared acessa os serviços via nome do container, não por porta de host.
# Estas portas são opcionais: úteis para acesso direto na rede local.
# ============================================================================
LIBRECHAT_PORT=4080
SUPERGATEWAY_PORT=4001
MCPO_PORT=4002
SWAGGER_MCP_PORT=4003

# ============================================================================
# LIBRECHAT — Chaves de Segurança
# Gere valores únicos com os comandos abaixo:
#   JWT_SECRET:          openssl rand -hex 32
#   JWT_REFRESH_SECRET:  openssl rand -hex 32
#   CREDS_KEY:           openssl rand -hex 32
#   CREDS_IV:            openssl rand -hex 16
# ============================================================================
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32
CREDS_KEY=CHANGE_ME_openssl_rand_hex_32
CREDS_IV=CHANGE_ME_openssl_rand_hex_16

# ============================================================================
# LIBRECHAT — Configurações de Acesso
# ============================================================================
# Banco de dados MongoDB (nome do banco)
MONGO_DB=librechat

# Permitir login por e-mail e registro de novos usuários
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true

# ============================================================================
# MEILISEARCH — Chave mestra
# Gere com: openssl rand -hex 32
# ============================================================================
MEILI_MASTER_KEY=CHANGE_ME_openssl_rand_hex_32

# ============================================================================
# VECTORDB — PostgreSQL + pgvector
# ============================================================================
VECTORDB_USER=pguser
VECTORDB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
VECTORDB_NAME=librechat_rag

# ============================================================================
# RAG API — Retrieval Augmented Generation
# Provedor de embeddings: openai | azure | huggingface | ollama
# ============================================================================
EMBEDDINGS_PROVIDER=openai

# ============================================================================
# APIs DE IA
# Use "user_provided" para que cada usuário insira sua própria chave na UI.
# Ou defina uma chave global de serviço aqui.
# ============================================================================
OPENAI_API_KEY=user_provided
ANTHROPIC_API_KEY=user_provided

# ============================================================================
# SUPERGATEWAY — Servidor MCP stdio → SSE
# Define qual servidor MCP stdio o supergateway irá encapsular.
# O LibreChat conecta neste endpoint via SSE para usar as ferramentas MCP.
#
# Exemplos:
#   Servidor demo (tudo incluído):
#     npx -y @modelcontextprotocol/server-everything
#   Acesso ao sistema de arquivos (montar volume no container também):
#     npx -y @modelcontextprotocol/server-filesystem /data
#   Fetch de URLs:
#     npx -y @modelcontextprotocol/server-fetch
#   Memória persistente:
#     npx -y @modelcontextprotocol/server-memory
# ============================================================================
SUPERGATEWAY_MCP_COMMAND=npx -y @modelcontextprotocol/server-everything

# ============================================================================
# SWAGGER-MCP — OpenAPI Spec → MCP via SSE
# URL da especificação OpenAPI/Swagger que será convertida em ferramentas MCP.
# O LibreChat conecta neste endpoint via SSE para usar os endpoints da API como ferramentas.
#
# Exemplos de spec URL:
#   API interna (Actual Budget):  http://actual:5007/api-docs/swagger.json
#   API interna (Habitica):       http://habitica:3000/api/v3/swagger.json
#   Petstore (demo público):      https://petstore.swagger.io/v2/swagger.json
#
# Se precisar de autenticação na API alvo, configure API_HEADERS no mcpo-config.json
# ============================================================================
SWAGGER_MCP_SPEC_URL=https://petstore.swagger.io/v2/swagger.json

# ============================================================================
# MCPO — API Key de Autenticação
# Usada para proteger o endpoint OpenAPI do mcpo contra acesso não autorizado.
# Gere com: openssl rand -hex 24
# ============================================================================
MCPO_API_KEY=CHANGE_ME_openssl_rand_hex_24
