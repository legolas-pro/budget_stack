# ============================================
# Immich - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e ajuste os valores

# Versão das imagens do Immich
IMMICH_VERSION=release
# Porta externa do Immich (mude se 2283 conflitar com outro serviço)
IMMICH_PORT=2283

# ---------- Volumes ----------
# Dados permanentes (fotos, vídeos, thumbs, backups) — recomendado HDD/pool grande
IMMICH_UPLOAD_LOCATION=/mnt/dados_hdd/immich/upload
# Fila temporária de processamento — recomendado NVMe/SSD rápido
# (sobrepõe o subdir upload/ dentro do container via bind mount)
IMMICH_UPLOAD_QUEUE_LOCATION=/srv/immich/upload/upload
# Dados do PostgreSQL — recomendado NVMe/SSD rápido
IMMICH_DB_DATA_LOCATION=/srv/immich/db

# ---------- Banco de dados ----------
IMMICH_DB_USER=immich
IMMICH_DB_NAME=immich
IMMICH_DB_PASSWORD=troque-por-senha-forte
