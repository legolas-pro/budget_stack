# ============================================================================
# ACTUAL BI - Configuracoes de Ambiente
# ============================================================================
# Copie este arquivo para actual-bi.env e preencha os valores
# Uso: docker stack deploy -c actual-bi.yaml actual-bi --env-file actual-bi.env
# ============================================================================

# ===== STACK =====
STACK_PREFIX=actual-bi

# ===== LOCALIZACAO =====
TZ=America/Sao_Paulo

# ===== IMAGENS =====
ACTUAL_BI_POSTGRES_IMAGE=postgres:16-alpine
ACTUAL_BI_SYNC_IMAGE=actual-bi-sync:local

# ===== POSTGRES BI =====
ACTUAL_BI_POSTGRES_PORT=55432
ACTUAL_BI_DB_NAME=actual_bi
ACTUAL_BI_DB_USER=actual_bi
ACTUAL_BI_DB_PASSWORD=<ALTERAR-senha-forte>
ACTUAL_BI_DB_SSLMODE=disable
ACTUAL_BI_DB_CONNECT_TIMEOUT_SECONDS=10
ACTUAL_BI_POSTGRES_DATA_VOLUME_NAME=actual_bi_postgres_data

# ===== USUARIO READ-ONLY (opcional) =====
# Se preencher, o worker cria/altera esse usuario com GRANT SELECT.
ACTUAL_BI_READONLY_DB_USER=actual_bi_ro
ACTUAL_BI_READONLY_DB_PASSWORD=<ALTERAR-senha-readonly>

# ===== ORIGEM: ACTUAL HTTP API =====
# Pode apontar para:
# - host local exposto (padrao): http://172.17.0.1:5007/v1
# - dominio interno/proxy:       https://actual-api.seudominio.com/v1
ACTUAL_HTTP_API_BASE_URL=http://172.17.0.1:5007/v1
ACTUAL_HTTP_API_KEY=<ALTERAR-mesma-chave-do-actual-api>
ACTUAL_HTTP_TIMEOUT_SECONDS=30
ACTUAL_HTTP_VERIFY_SSL=true
ACTUAL_HTTP_RETRIES=3
ACTUAL_HTTP_BACKOFF_SECONDS=2

# ===== ESCOPO DE INGESTAO =====
ACTUAL_BI_ENDPOINTS=accounts,transactions,payees,categories
# Opcional: filtrar budgets especificos (CSV)
ACTUAL_BI_BUDGET_IDS=
# true = falha se /budgets vier vazio (evita apagar tudo por erro de origem)
ACTUAL_BI_REQUIRE_NON_EMPTY_BUDGETS=true
# true = qualquer erro de endpoint aborta ciclo inteiro (consistencia > parcial)
ACTUAL_BI_FAIL_ON_ENDPOINT_ERROR=true

# ===== WORKER =====
ACTUAL_BI_SYNC_INTERVAL_SECONDS=300
ACTUAL_BI_SYNC_RUN_ONCE=false
ACTUAL_BI_SYNC_LOG_LEVEL=INFO

# ============================================================================
# DEPLOY
# ============================================================================
# 1. Copie para actual-bi.env e preencha os segredos
# 2. Build da imagem do worker (obrigatorio antes do primeiro deploy e apos updates):
#      docker build -t actual-bi-sync:local nodes/fin-tools/actual-bi-sync/
# 3. Deploy da stack:
#      docker stack deploy -c actual-bi.yaml actual-bi --env-file actual-bi.env
#
# 4. Conferir servicos:
#      docker service ls | grep actual-bi
#
# 5. Conferir logs do worker:
#      docker service logs -f actual-bi_actual_bi_sync
#
# 6. Conexao direta no Postgres:
#    host: <IP-do-manager>
#    port: ${ACTUAL_BI_POSTGRES_PORT}
#    db:   ${ACTUAL_BI_DB_NAME}
#    user: ${ACTUAL_BI_READONLY_DB_USER} (ou ACTUAL_BI_DB_USER)
#
# Tabelas principais:
#   - actual_budgets
#   - actual_entities
#   - actual_sync_state
# Views:
#   - actual_active_transactions
#   - actual_active_accounts
# ============================================================================
