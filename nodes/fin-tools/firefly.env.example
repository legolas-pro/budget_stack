# ============================================================================
# STACK: Firefly III - Gerenciador de Finanças Pessoais
# VERSÃO: 1.0
# VPS: fin-tools
# ============================================================================
#
# INSTRUÇÕES:
#   1. Copie este arquivo para firefly.env
#   2. Preencha todas as variáveis marcadas com <ALTERAR>
#   3. Gere as chaves secretas com os comandos abaixo
#   4. Execute: docker stack deploy -c firefly.yaml firefly --env-file firefly.env
#
# GERAR CHAVES:
#   FIREFLY_APP_KEY (32 caracteres):
#     head /dev/urandom | tr -dc A-Za-z0-9 | head -c 32
#
#   FIREFLY_CRON_TOKEN (32 caracteres):
#     head /dev/urandom | tr -dc A-Za-z0-9 | head -c 32
#
# ============================================================================

# ============================================================================
# MARIADB - Banco de dados
# ============================================================================
FIREFLY_MARIADB_ROOT_PASSWORD=<ALTERAR-senha-root-mariadb>

# ============================================================================
# FIREFLY III
# https://docs.firefly-iii.org/
# ============================================================================

# Porta exposta (0.0.0.0:PORTA)
FIREFLY_PORT=8080

# Banco de dados
FIREFLY_DB_NAME=firefly
FIREFLY_DB_USER=firefly
FIREFLY_DB_PASSWORD=<ALTERAR-senha-firefly-db>

# Aplicação (gere com: head /dev/urandom | tr -dc A-Za-z0-9 | head -c 32)
FIREFLY_APP_KEY=<ALTERAR-chave-32-caracteres>

# Token para cron job (gere com: head /dev/urandom | tr -dc A-Za-z0-9 | head -c 32)
FIREFLY_CRON_TOKEN=<ALTERAR-cron-token-32-caracteres>

# Email (opcional - deixe log para desabilitar)
FIREFLY_MAIL_MAILER=log
FIREFLY_MAIL_HOST=smtp.google.com
FIREFLY_MAIL_PORT=465
FIREFLY_MAIL_FROM=firefly@dinamopro.com
FIREFLY_MAIL_USER=
FIREFLY_MAIL_PASSWORD=
FIREFLY_MAIL_ENCRYPTION=ssl

# ============================================================================
# LAMPYRID MCP - Model Context Protocol para Firefly III (ACESSO INTERNO)
# https://github.com/RadCod3/LamPyrid
# ============================================================================

# Porta local do MCP (acesso apenas interno, sem domínio público)
FIREFLY_MCP_PORT=3002

# Imagem do MCP (altere para pin de versão se necessário)
FIREFLY_MCP_IMAGE=ghcr.io/radcod3/lampyrid:latest

# URL interna do Firefly III acessada pelo MCP
# Altere somente se mudar a porta ou o nome do serviço no yaml
FIREFLY_MCP_SERVER_URL=http://app:8080

# Personal Access Token do Firefly III
# Gere em: Firefly → Options → Profile → OAuth → Personal Access Token
FIREFLY_API_TOKEN=<ALTERAR-token-firefly-api>

# Nível de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
FIREFLY_MCP_LOG_LEVEL=INFO

# ============================================================================
# ENDPOINTS (após deploy)
# ============================================================================
#
# Firefly III:   http://localhost:8080
# LamPyrid MCP:  http://localhost:3002 (interno)
#
# ============================================================================
# INTEGRAÇÃO VIA N8N
# ============================================================================
#
# Firefly III API (direto):
#   - Documentação: https://api-docs.firefly-iii.org/
#   - Criar token em: Firefly → Options → Profile → OAuth → Personal Access Token
#   - Endpoint: http://localhost:8080/api/v1/di
#
# LamPyrid MCP (SSE) - ACESSO INTERNO:
#   - Documentação: https://github.com/RadCod3/LamPyrid
#   - Endpoint SSE no N8N: http://172.17.0.1:3002/sse
#   - Alternativa: http://host.docker.internal:3002/sse
#   - Suporta contas, transações e orçamentos (leitura e escrita)
#
# ============================================================================
