# ============================================================================
# PLUGGY MCP - Configurações de Ambiente
# ============================================================================
# Copie este arquivo para pluggy.env e preencha os valores
# Uso: docker stack deploy -c pluggy.yaml pluggy --env-file pluggy.env
# ============================================================================

# ===== STACK =====
STACK_PREFIX=pluggy

# ===== LOCALIZAÇÃO =====
TZ=America/Sao_Paulo

# ===== IMAGEM =====
# Imagem local (buildar antes do deploy — ver instruções abaixo)
PLUGGY_MCP_IMAGE=pluggy-mcp:local

# ===== PORTA =====
# Pluggy MCP (streamableHttp — endpoint: /mcp)
PLUGGY_MCP_PORT=3002

# ===== CREDENCIAIS PLUGGY =====
# Obtenha em: https://dashboard.pluggy.ai > Aplicações > sua app > Client ID / Secret
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# ============================================================================
# ENDPOINTS (após deploy)
# ============================================================================
#
# Pluggy MCP: http://localhost:3002/mcp
#
# ============================================================================
# DEPLOY
# ============================================================================
# 1. Copie para pluggy.env e preencha PLUGGY_CLIENT_ID e PLUGGY_CLIENT_SECRET
# 2. Clone o fonte e coloque dentro de nodes/fin-tools/pluggy-mcp/:
#      git clone https://github.com/pluggyai/pluggy-mcp.git /tmp/pluggy-mcp
#      cp -r /tmp/pluggy-mcp/* nodes/fin-tools/pluggy-mcp/
#      (o Dockerfile já está lá — não sobrescreva)
# 3. Build da imagem:
#      docker build -t pluggy-mcp:local nodes/fin-tools/pluggy-mcp/
# 4. Deploy:
#      docker stack deploy -c pluggy.yaml pluggy --env-file pluggy.env
# ============================================================================
