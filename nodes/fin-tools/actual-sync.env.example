# ============================================================================
# STACK: Actual Snapshot Sync -> SQLite View-Only
# VERSAO: 2.0
# ============================================================================
#
# INSTRUCOES:
#   1. Copie este arquivo para actual-sync.env
#   2. Ajuste o nome do volume do Actual e do volume BI
#   3. Build da imagem worker:
#        docker build -t actual-sync:local nodes/fin-tools/actual-sync/
#   4. Deploy da stack:
#        docker stack deploy -c actual-sync.yaml actual-sync --env-file actual-sync.env
#
# ============================================================================

# ===== STACK =====
STACK_PREFIX=actual-sync
TZ=America/Sao_Paulo

# ===== IMAGEM =====
ACTUAL_SYNC_IMAGE=actual-sync:local

# ===== VOLUME DE ORIGEM (Actual) =====
# Nome real do volume de dados do Actual no Docker Swarm.
# Padrao mais comum quando a stack se chama "actual": actual_actual_data
ACTUAL_VOLUME_NAME=actual_actual_data

# ===== VOLUME DE SAIDA (SQLite para BI) =====
# Este volume deve ser montado no Metabase em modo read-only.
ACTUAL_BI_VOLUME_NAME=actual_bi_data
ACTUAL_BI_DB_FILE=actual_bi.sqlite
ACTUAL_BI_METADATA_FILE=actual_bi.metadata.json

# Opcional: se quiser fixar exatamente o arquivo de origem no volume do Actual.
# Exemplo: ACTUAL_SOURCE_DB_FILENAME=actual.sqlite
ACTUAL_SOURCE_DB_FILENAME=

# ===== WORKER =====
ACTUAL_SYNC_INTERVAL_SECONDS=180
ACTUAL_SYNC_SKIP_UNCHANGED=true
ACTUAL_SYNC_FORCE_COPY=false
ACTUAL_SYNC_SET_OUTPUT_READONLY=true
ACTUAL_SYNC_RUN_ONCE=false
ACTUAL_SYNC_LOG_LEVEL=INFO

# Extensoes para descobrir snapshots SQLite no volume
ACTUAL_SNAPSHOT_EXTENSIONS=.sqlite,.sqlite3,.db

# ============================================================================
# COMO LIGAR NO METABASE (DRIVER SQLITE)
# ============================================================================
# 1) No metabase.yaml, monte o volume externo no container metabase:
#
# volumes:
#   actual_bi_data:
#     external: true
#     name: actual_bi_data
#
# services:
#   metabase:
#     volumes:
#       - actual_bi_data:/bi:ro
#
# 2) No Metabase, configure o SQLite apontando para:
#    /bi/actual_bi.sqlite
# ============================================================================
