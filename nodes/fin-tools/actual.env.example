# ============================================================================
# STACK: Actual Budget - Orçamento Pessoal
# VERSÃO: 1.2
# VPS: fin-tools
# ============================================================================
#
# INSTRUÇÕES:
#   1. Copie este arquivo para actual.env
#   2. Preencha todas as variáveis marcadas com <ALTERAR>
#   3. Execute: docker stack deploy -c actual.yaml actual --env-file actual.env
#
# ============================================================================

# ============================================================================
# ACTUAL BUDGET - Orçamento Pessoal
# https://actualbudget.org/docs/
# ============================================================================

# Porta exposta (0.0.0.0:PORTA)
ACTUAL_PORT=5006

# Senha do servidor Actual (definida no primeiro acesso ao Actual Budget)
ACTUAL_PASSWORD=<ALTERAR-senha-actual-server>

# ============================================================================
# ACTUAL HTTP API - REST API para integração com N8N
# https://github.com/jhonderson/actual-http-api
# ============================================================================

# Porta da API REST
ACTUAL_API_PORT=5007

# Chave de autenticação da API (usada no header: x-api-key)
ACTUAL_API_KEY=<ALTERAR-chave-api>

# ============================================================================
# ACTUAL MCP - Model Context Protocol
# https://github.com/s-stefanov/actual-mcp
# ============================================================================

# Porta do MCP (streamableHttp — endpoint: /mcp)
ACTUAL_MCP_PORT=3001

# Imagem local (buildar antes do deploy — ver instruções abaixo)
ACTUAL_MCP_IMAGE=actual-mcp:local

# URL interna do Actual Budget acessada pelo MCP (padrão: http://app:5006)
# Altere somente se mudar a porta ou o nome do serviço no yaml
ACTUAL_MCP_SERVER_URL=http://app:5006

# Sync ID do orçamento (fixo — não muda)
ACTUAL_BUDGET_SYNC_ID=e2f9114e-f3b6-4a0c-b2cd-2586e267bc8a

# Opcional: senha de criptografia do orçamento (somente se diferente de ACTUAL_PASSWORD)
ACTUAL_BUDGET_ENCRYPTION_PASSWORD=

# ============================================================================
# ACTUAL BI (PostgreSQL + worker de upsert conservador)
# ============================================================================

# Imagens
ACTUAL_BI_POSTGRES_IMAGE=postgres:16-alpine
ACTUAL_BI_SYNC_IMAGE=actual-bi-sync:local

# PostgreSQL de BI (conexao direta por ferramentas externas)
ACTUAL_BI_POSTGRES_PORT=55432
ACTUAL_BI_DB_NAME=actual_bi
ACTUAL_BI_DB_USER=actual_bi
ACTUAL_BI_DB_PASSWORD=<ALTERAR-senha-forte>
ACTUAL_BI_DB_SSLMODE=disable
ACTUAL_BI_DB_CONNECT_TIMEOUT_SECONDS=10
ACTUAL_BI_POSTGRES_DATA_VOLUME_NAME=actual_bi_postgres_data

# Usuario read-only opcional (recomendado para Metabase/BI)
ACTUAL_BI_READONLY_DB_USER=actual_bi_ro
ACTUAL_BI_READONLY_DB_PASSWORD=<ALTERAR-senha-readonly>

# Origem do worker: actual-http-api desta mesma stack
ACTUAL_HTTP_TIMEOUT_SECONDS=30
ACTUAL_HTTP_VERIFY_SSL=true
ACTUAL_HTTP_RETRIES=3
ACTUAL_HTTP_BACKOFF_SECONDS=2

# Escopo de ingestao (1 budget: pode manter tudo vazio no filtro)
ACTUAL_BI_ENDPOINTS=accounts,transactions,payees,categories
ACTUAL_BI_BUDGET_IDS=
ACTUAL_BI_REQUIRE_NON_EMPTY_BUDGETS=true
ACTUAL_BI_FAIL_ON_ENDPOINT_ERROR=true

# Worker
ACTUAL_BI_SYNC_INTERVAL_SECONDS=300
ACTUAL_BI_SYNC_RUN_ONCE=false
ACTUAL_BI_SYNC_LOG_LEVEL=INFO

# ============================================================================
# ENDPOINTS (após deploy)
# ============================================================================
#
# Actual Budget:   http://localhost:5006
# Actual HTTP API: http://localhost:5007
# Actual MCP:      http://localhost:3001/mcp
# BI Postgres:     host do manager : ${ACTUAL_BI_POSTGRES_PORT}
#
# ============================================================================
# INTEGRAÇÃO VIA N8N
# ============================================================================
#
# Actual HTTP API (REST) - ACESSO INTERNO:
#   - Documentação: https://github.com/jhonderson/actual-http-api
#   - Base URL no N8N: http://172.17.0.1:5007
#   - Alternativa: http://host.docker.internal:5007
#   - API REST completa para orçamentos, contas e transações
#
# ============================================================================
# DEPLOY
# ============================================================================
# 1. Copie para actual.env e preencha os segredos
# 2. Build das imagens locais (obrigatório antes do primeiro deploy e após atualizações):
#      docker build -t actual-mcp:local nodes/fin-tools/actual-mcp/
#      docker build -t actual-bi-sync:local nodes/fin-tools/actual-bi-sync/
# 3. Deploy unificado (app + api + mcp + bi-postgres + bi-sync):
#      docker stack deploy -c actual.yaml actual --env-file actual.env
# 4. Se voce ja tinha a stack separada "actual-bi", remova para evitar double-ingest:
#      docker stack rm actual-bi
# ============================================================================
