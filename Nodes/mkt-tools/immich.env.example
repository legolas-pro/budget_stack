# ============================================
# Immich + n8n - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e ajuste os valores

# -----------------------------------------------
# IMMICH
# -----------------------------------------------

# --- Versão ---
# Tag das imagens do Immich (server, microservices, machine-learning)
IMMICH_VERSION=release

# --- Imagens ---
# Imagem do Redis/Valkey
IMMICH_REDIS_IMAGE=docker.io/valkey/valkey:9-alpine
# Imagem do Postgres com extensão pgvecto.rs
IMMICH_DB_IMAGE=ghcr.io/immich-app/postgres:16-16.6

# --- Réplicas ---
# Réplicas do servidor principal
IMMICH_SERVER_REPLICAS=1
# Réplicas dos microservices (processamento de jobs)
IMMICH_MICROSERVICES_REPLICAS=1
# Réplicas do machine learning (reconhecimento facial, etc.)
IMMICH_ML_REPLICAS=1

# --- Recursos ---
# Limite de memória do servidor principal
IMMICH_SERVER_MEMORY_LIMIT=2G

# --- Volumes / Paths ---
# Caminho no host para uploads de fotos/vídeos
IMMICH_UPLOAD_LOCATION=/srv/immich/upload
# Caminho no host para dados do Postgres
IMMICH_DB_DATA_LOCATION=/srv/immich/db

# --- Banco de Dados (Immich) ---
# Nome do banco de dados
IMMICH_DB_NAME=immich
# Usuário do banco de dados
IMMICH_DB_USERNAME=immich
# Senha do banco de dados (OBRIGATÓRIO - altere!)
IMMICH_DB_PASSWORD=troque-por-senha-forte

# --- Variáveis internas do Immich (lidas via env_file) ---
# URL de conexão ao banco (montada a partir das vars acima)
DB_URL=postgresql://immich:troque-por-senha-forte@database:5432/immich
# Hostname do Redis
REDIS_HOSTNAME=redis

# -----------------------------------------------
# N8N
# -----------------------------------------------

# --- Imagem ---
# Imagem do n8n
N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
# Imagem do Postgres do n8n
N8N_DB_IMAGE=postgres:16-alpine

# --- Réplicas ---
# Número de réplicas do n8n
N8N_REPLICAS=1

# --- Placement (Swarm) ---
# Role do node onde o n8n será deployado
N8N_NODE_ROLE=manager

# --- Rede / Domínio ---
# Hostname do n8n
N8N_HOST=seu-dominio.com
# Protocolo (http ou https)
N8N_PROTOCOL=https
# URL do webhook (inclua barra final)
N8N_WEBHOOK_URL=https://seu-dominio.com/
# Porta exposta do n8n
N8N_PORT=5678

# --- Timezone ---
# Timezone do n8n
N8N_TIMEZONE=America/Sao_Paulo

# --- Banco de Dados (n8n) ---
# Nome do banco de dados do n8n
N8N_DB_NAME=n8n
# Usuário do banco de dados do n8n (OBRIGATÓRIO)
N8N_DB_USER=n8n
# Senha do banco de dados do n8n (OBRIGATÓRIO - altere!)
N8N_DB_PASSWORD=troque-por-senha-forte
