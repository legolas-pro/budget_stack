# ============================================================================
# Clinicia-njs-v3 - Variáveis de Ambiente
# Stack: clinicia-njs-out-v3.yaml (N8N Production Stack)
# ============================================================================
# Copie este arquivo para clinicia-njs-out-v3.env e preencha os valores
# Uso: docker stack deploy -c clinicia-njs-out-v3.yaml clinicia-njs --env-file clinicia-njs-out-v3.env

# ============================================================================
# IDENTIFICADOR DA STACK (diferencia staging/production no Traefik)
# ============================================================================
TRAEFIK_PREFIX=clinicia-njs

# ============================================================================
# PORTAS EXTERNAS (para acesso fora do Docker)
# ============================================================================
POSTGRES_PORT_EXTERNAL=5432
REDIS_PORT_EXTERNAL=6379

# ============================================================================
# BANCO DE DADOS
# ============================================================================
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=n8n_queue

# ============================================================================
# N8N - CONFIGURAÇÕES PRINCIPAIS
# ============================================================================
# Chave de criptografia - GERE UMA CHAVE ÚNICA E SEGURA
# Exemplo: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_SECURE_KEY

# Hosts/URLs
N8N_HOST=clinicia-njs.dinamopro.ai
WEBHOOK_HOST=clinicia-wh.dinamopro.ai

# ============================================================================
# SMTP - CONFIGURAÇÃO DE E-MAIL
# ============================================================================
SMTP_SENDER=bot@dinamopro.online
SMTP_USER=bot@dinamopro.online
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465

# ============================================================================
# INTEGRAÇÕES / IA
# ============================================================================
OPENAI_API_KEY=sk-CHANGE_ME_OPENAI_KEY
