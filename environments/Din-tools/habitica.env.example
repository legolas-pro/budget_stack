# ============================================================================
# STACK: Habitica - Gamificação de Hábitos
# VERSÃO: 1.0
# VPS: Din-tools
# ============================================================================
#
# INSTRUÇÕES:
#   1. Copie este arquivo para habitica.env
#   2. Preencha todas as variáveis marcadas com <ALTERAR>
#   3. Gere a chave de sessão com o comando abaixo
#   4. Execute: docker stack deploy -c habitica.yaml habitica
#
# GERAR CHAVE:
#   HABITICA_SESSION_SECRET:
#     openssl rand -hex 32
#
# ============================================================================

# ============================================================================
# HABITICA - Gamificação de Hábitos (awinterstein fork)
# https://github.com/awinterstein/habitica
# Server: https://hub.docker.com/r/awinterstein/habitica-server
# Client: https://hub.docker.com/r/awinterstein/habitica-client
# ============================================================================

# Banco de dados
HABITICA_DB_NAME=habitica

# Sessão (gere com: openssl rand -hex 32)
HABITICA_SESSION_SECRET=<ALTERAR-session-secret>

# Host/Domínio
HABITICA_HOST=habitica.dinamopro.com

# Admin
HABITICA_ADMIN_EMAIL=admin@dinamopro.com

# ============================================================================
# ENDPOINTS (após deploy)
# ============================================================================
#
# Habitica: https://habitica.dinamopro.com
#
# ============================================================================
# INTEGRAÇÃO VIA N8N
# ============================================================================
#
# Habitica API:
#   - Documentação: https://habitica.com/apidoc/
#   - Obter credenciais em: Habitica → Settings → API
#   - Headers: x-api-user, x-api-key
#   - Endpoint: https://habitica.dinamopro.com/api/v3/
#
# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
#
# 1. O Habitica requer MongoDB com Replica Set (configurado automaticamente)
#
# 2. Primeiro deploy pode demorar ~3 minutos para o server ficar healthy
#    (aguardando MongoDB replica set inicializar)
#
# 3. Se o client não conseguir conectar ao server, verifique os logs:
#    docker service logs habitica_client
#    docker service logs habitica_server
#
# 4. O DNS interno do Swarm registra o server como "habitica_server"
#    (stack_service = habitica_server)
#
# ============================================================================
