# ============================================================================
# Din-njs-v3 - Variáveis de Ambiente
# Stack: din-njs-v3.yaml (N8N Production Stack)
# ============================================================================
# Copie este arquivo para din-njs-v3.env e preencha os valores
# Uso: docker stack deploy -c din-njs-v3.yaml din-njs --env-file din-njs-v3.env

# ============================================================================
# IDENTIFICADOR DA STACK (diferencia staging/production no Traefik)
# ============================================================================
TRAEFIK_PREFIX=din-njs

# ============================================================================
# PORTAS EXTERNAS (para acesso fora do Docker)
# ============================================================================
POSTGRES_PORT_EXTERNAL=5435
REDIS_PORT_EXTERNAL=6380

# ============================================================================
# BANCO DE DADOS
# ============================================================================
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=n8n_queue

# ============================================================================
# N8N - CONFIGURAÇÕES PRINCIPAIS
# ============================================================================
# Chave de criptografia - GERE UMA CHAVE ÚNICA E SEGURA
# Exemplo: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_SECURE_KEY

# Hosts/URLs
N8N_HOST=din-njs.dinamopro.com
WEBHOOK_HOST=din-wh.dinamopro.com

# ============================================================================
# SMTP - CONFIGURAÇÃO DE E-MAIL
# ============================================================================
SMTP_SENDER=legolas@dinamopro.com
SMTP_USER=legolas@dinamopro.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_HOST=smtp.google.com
SMTP_PORT=465

# ============================================================================
# INTEGRAÇÕES / IA
# ============================================================================
OPENAI_API_KEY=sk-CHANGE_ME_OPENAI_KEY
