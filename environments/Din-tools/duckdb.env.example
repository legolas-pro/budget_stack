# ============================================================================
# STACK: DuckDB + Duck-UI
# VERSÃO: 1.0
# ============================================================================
#
# INSTRUÇÕES:
#   1. Copie este arquivo para duckdb.env
#   2. Ajuste as variáveis conforme o contexto do computador/VPS
#   3. Execute: docker stack deploy -c duckdb.yaml duckdb
#
# ============================================================================

# ============================================================================
# GERAL
# ============================================================================
TZ=America/Sao_Paulo

# ============================================================================
# DUCK-UI - Interface Web
# ============================================================================

# Porta exposta no host (Cloudflared aponta para esta porta)
DUCK_UI_PORT=3088
# Porta interna do container (verificar com: docker exec ... netstat -tlnp)
DUCK_UI_INTERNAL_PORT=5522

# ============================================================================
# DUCKDB - Motor Analítico
# ============================================================================

# Caminho interno dos dados (onde os .duckdb ficam armazenados)
DUCKDB_DATA_PATH=/data

# Nome do banco de dados principal
DUCKDB_DATABASE=main.db

# Porta da UI nativa do DuckDB exposta no host
DUCKDB_UI_PORT=3099
# Porta interna da UI nativa no container
DUCKDB_UI_INTERNAL_PORT=4213

# ============================================================================
# RECURSOS - Ajuste conforme capacidade da máquina
# ============================================================================

# DuckDB CLI
DUCKDB_CPU_LIMIT=1.0
DUCKDB_MEMORY_LIMIT=1024M

# Duck-UI
DUCK_UI_CPU_LIMIT=1.0
DUCK_UI_MEMORY_LIMIT=1024M

# ============================================================================
# ENDPOINTS (após deploy)
# ============================================================================
#
# Duck-UI:       http://localhost:3088
# DuckDB UI:     http://localhost:3099
#
# DuckDB CLI (ad-hoc):
#   docker exec -it $(docker ps -q -f name=duckdb_duckdb) duckdb /data/main.db
#
# Cloudflared:
#   Apontar o tunnel para http://localhost:3088
#
# ============================================================================
