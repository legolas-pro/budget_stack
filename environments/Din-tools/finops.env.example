# ============================================================================
# STACK: FinOps (Financial Operations)
# VERSÃO: 1.2
# VPS: Din-tools
# ============================================================================
#
# INSTRUÇÕES:
#   1. Copie este arquivo para finops.env
#   2. Preencha todas as variáveis marcadas com <ALTERAR>
#   3. Gere as chaves secretas com os comandos abaixo
#   4. Execute: docker stack deploy -c finops.yaml finops
#
# GERAR CHAVES:
#   FIREFLY_APP_KEY (32 caracteres):
#     head /dev/urandom | tr -dc A-Za-z0-9 | head -c 32
#
#   HABITICA_SESSION_SECRET:
#     openssl rand -hex 32
#
# ============================================================================

# ============================================================================
# MARIADB - Banco de dados do Firefly III
# ============================================================================
MARIADB_ROOT_PASSWORD=<ALTERAR-senha-root-mariadb>

# ============================================================================
# MONGODB - Banco de dados do Habitica
# ============================================================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=<ALTERAR-senha-root-mongodb>

# ============================================================================
# FIREFLY III - Gerenciador de Finanças
# https://docs.firefly-iii.org/
# ============================================================================

# Banco de dados
FIREFLY_DB_NAME=firefly
FIREFLY_DB_USER=firefly
FIREFLY_DB_PASSWORD=<ALTERAR-senha-firefly-db>

# Aplicação (gere com: head /dev/urandom | tr -dc A-Za-z0-9 | head -c 32)
FIREFLY_APP_KEY=<ALTERAR-chave-32-caracteres>

# Host/Domínio
FIREFLY_HOST=firefly.dinamopro.com

# Email (opcional - deixe log para desabilitar)
FIREFLY_MAIL_MAILER=log
FIREFLY_MAIL_HOST=smtp.google.com
FIREFLY_MAIL_PORT=465
FIREFLY_MAIL_FROM=firefly@dinamopro.com
FIREFLY_MAIL_USER=
FIREFLY_MAIL_PASSWORD=
FIREFLY_MAIL_ENCRYPTION=ssl

# ============================================================================
# HABITICA - Gamificação de Hábitos
# https://github.com/HabitRPG/habitica
# ============================================================================

# Banco de dados
HABITICA_DB_NAME=habitica

# Sessão (gere com: openssl rand -hex 32)
HABITICA_SESSION_SECRET=<ALTERAR-session-secret>

# Host/Domínio
HABITICA_HOST=habitica.dinamopro.com

# Admin
HABITICA_ADMIN_EMAIL=admin@dinamopro.com

# ============================================================================
# ACTUAL BUDGET - Orçamento Pessoal
# https://actualbudget.org/docs/
# ============================================================================

# Host/Domínio
ACTUAL_HOST=actual.dinamopro.com

# Senha do servidor Actual (definida no primeiro acesso ao Actual Budget)
ACTUAL_PASSWORD=<ALTERAR-senha-actual-server>

# ============================================================================
# ACTUAL MCP - Model Context Protocol para N8N (ACESSO INTERNO)
# https://github.com/s-stefanov/actual-mcp
# ============================================================================

# Porta local do MCP (acesso apenas interno, sem domínio público)
ACTUAL_MCP_PORT=3001

# ID do orçamento específico (opcional - deixe vazio para usar o padrão)
# Pode ser encontrado em Actual Budget → Settings → Show advanced settings
ACTUAL_BUDGET_SYNC_ID=

# Senha de encriptação do orçamento (se diferente da senha do servidor)
ACTUAL_BUDGET_ENCRYPTION_PASSWORD=

# ============================================================================
# ENDPOINTS (após deploy)
# ============================================================================
#
# Firefly III:  https://firefly.dinamopro.com
# Habitica:     https://habitica.dinamopro.com
# Actual:       https://actual.dinamopro.com
# Actual MCP:   http://localhost:3001 (interno)
#
# ============================================================================
# INTEGRAÇÃO VIA N8N
# ============================================================================
#
# Firefly III API:
#   - Documentação: https://api-docs.firefly-iii.org/
#   - Criar token em: Firefly → Options → Profile → OAuth → Personal Access Token
#   - Endpoint: https://firefly.dinamopro.com/api/v1/
#
# Habitica API:
#   - Documentação: https://habitica.com/apidoc/
#   - Obter credenciais em: Habitica → Settings → API
#   - Headers: x-api-user, x-api-key
#   - Endpoint: https://habitica.dinamopro.com/api/v3/
#
# Actual MCP (SSE) - ACESSO INTERNO:
#   - Documentação: https://github.com/s-stefanov/actual-mcp
#   - Endpoint SSE no N8N: http://172.17.0.1:3001/sse
#   - Alternativa: http://host.docker.internal:3001/sse
#   - O MCP conecta diretamente ao Actual Budget server interno
#   - Suporta leitura e escrita de transações (--enable-write)
#
# Habitica MCP (SSE) - DESATIVADO:
#   - Motivo: URL hardcoded para habitica.com (não suporta self-hosted)
#   - Solução: criar fork com HABITICA_API_URL configurável
#   - Para ativar: no finops.yaml, altere replicas de 0 para 1
#   - Variáveis necessárias quando ativado:
#       HABITICA_MCP_PORT=3002
#       HABITICA_USER_ID=<seu-user-id>
#       HABITICA_API_TOKEN=<seu-api-token>
#
# ============================================================================
