# ============================================================================
# MCP MESH + SLACK MCP SERVER - Variáveis de Ambiente
# VPS: Din-tools
# ============================================================================

# ============================================================================
# DOMÍNIO (OBRIGATÓRIO)
# ============================================================================
MCP_MESH_DOMAIN=mesh.dinamopro.com

# ============================================================================
# POSTGRESQL
# ============================================================================
POSTGRES_DB=mesh_db
POSTGRES_USER=mesh_user
# OBRIGATÓRIO - Defina uma senha forte
POSTGRES_PASSWORD=sua_senha_segura_aqui

# ============================================================================
# MCP MESH - AUTENTICAÇÃO (OBRIGATÓRIO)
# Gerar com: openssl rand -base64 32
# ============================================================================
BETTER_AUTH_SECRET=

# ============================================================================
# MCP MESH - CRIPTOGRAFIA (OBRIGATÓRIO)
# Gerar com: openssl rand -hex 32
# ============================================================================
ENCRYPTION_KEY=

# ============================================================================
# IMAGEM DOCKER MCP MESH (Opcional - já possui defaults)
# ============================================================================
# IMAGE_REPOSITORY=ghcr.io/decocms/mesh/mesh
# IMAGE_TAG=latest

# ============================================================================
# AMBIENTE NODE (Opcional - default: production)
# ============================================================================
# NODE_ENV=production

# ============================================================================
# SLACK MCP SERVER - API KEY (OBRIGATÓRIO)
# Gerar com: openssl rand -hex 32
# Usado para autenticar requisições SSE ao servidor
# ============================================================================
SLACK_MCP_SSE_API_KEY=

# ============================================================================
# SLACK MCP SERVER - BOT TOKEN (OBRIGATÓRIO)
# Token do seu Slack Bot App (começa com xoxb-)
# Obter em: https://api.slack.com/apps > OAuth & Permissions
# ============================================================================
SLACK_MCP_XOXB_TOKEN=xoxb-seu-token-aqui

# ============================================================================
# SLACK MCP SERVER - OPCIONAIS
# ============================================================================
# Nível de log: debug, info, warn, error
# SLACK_MCP_LOG_LEVEL=info

# Habilitar envio de mensagens (CUIDADO - desabilitado por segurança)
# SLACK_MCP_ADD_MESSAGE_TOOL=true
