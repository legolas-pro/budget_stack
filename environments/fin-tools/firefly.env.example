# ============================================================================
# STACK: Firefly III - Gerenciador de Finanças Pessoais
# VERSÃO: 1.0
# VPS: fin-tools
# ============================================================================
#
# INSTRUÇÕES:
#   1. Copie este arquivo para firefly.env
#   2. Preencha todas as variáveis marcadas com <ALTERAR>
#   3. Gere as chaves secretas com os comandos abaixo
#   4. Execute: docker stack deploy -c firefly.yaml firefly
#
# GERAR CHAVES:
#   FIREFLY_APP_KEY (32 caracteres):
#     head /dev/urandom | tr -dc A-Za-z0-9 | head -c 32
#
#   FIREFLY_CRON_TOKEN (32 caracteres):
#     head /dev/urandom | tr -dc A-Za-z0-9 | head -c 32
#
# ============================================================================

# ============================================================================
# MARIADB - Banco de dados
# ============================================================================
MARIADB_ROOT_PASSWORD=<ALTERAR-senha-root-mariadb>

# ============================================================================
# FIREFLY III
# https://docs.firefly-iii.org/
# ============================================================================

# Porta exposta (0.0.0.0:PORTA)
FIREFLY_PORT=8080

# Banco de dados
FIREFLY_DB_NAME=firefly
FIREFLY_DB_USER=firefly
FIREFLY_DB_PASSWORD=<ALTERAR-senha-firefly-db>

# Aplicação (gere com: head /dev/urandom | tr -dc A-Za-z0-9 | head -c 32)
FIREFLY_APP_KEY=<ALTERAR-chave-32-caracteres>

# Token para cron job (gere com: head /dev/urandom | tr -dc A-Za-z0-9 | head -c 32)
FIREFLY_CRON_TOKEN=<ALTERAR-cron-token-32-caracteres>

# Email (opcional - deixe log para desabilitar)
FIREFLY_MAIL_MAILER=log
FIREFLY_MAIL_HOST=smtp.google.com
FIREFLY_MAIL_PORT=465
FIREFLY_MAIL_FROM=firefly@dinamopro.com
FIREFLY_MAIL_USER=
FIREFLY_MAIL_PASSWORD=
FIREFLY_MAIL_ENCRYPTION=ssl

# ============================================================================
# LAMPYRID MCP - Model Context Protocol para Firefly III (ACESSO INTERNO)
# https://github.com/RadCod3/LamPyrid
# ============================================================================

# Porta local do MCP (acesso apenas interno, sem domínio público)
LAMPYRID_MCP_PORT=3002

# Personal Access Token do Firefly III
# Gere em: Firefly → Options → Profile → OAuth → Personal Access Token
FIREFLY_API_TOKEN=<eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9.eyJhdWQiOiIxIiwianRpIjoiMDMxZWIwOGMyYzU3Y2VkOWYzYmZlZTQ1ODhlOTFmYmU4YTEyZWIzOTMwOTE3MjkwOGU5MmNhOWEyOTRkNjAwYTZmYzcwNjk2YjQxZmU0MDAiLCJpYXQiOjE3NzA1NTg2NzguMDA5NDQ4LCJuYmYiOjE3NzA1NTg2NzguMDA5NDUsImV4cCI6MTgwMjA5NDY3Ny44Nzk1MTUsInN1YiI6IjEiLCJzY29wZXMiOltdfQ.cI6d-LQ5gnq8mYQOGiM59uYLi-AWuySlmZVT_4cW2s6-yY2p2t_9G52IVBSClIplkJN1DqnG0qIHqXvgYJZ5F403B_Z0fLdr5aYenZyfBWHmBEwb2VdNrMnkeq5-ewsgWCHiRPLqQ4R_a_8x8124XMP6SUcdwNLxgsOzo0Viz60WY_LPYVsjdiFOPh9LBhYNzcjFSZdBl_no2QtXgh6QTwwdU8RLAQXGlhgufSKgJ6k1CiZnm7nH0wFEvKKnCFQ4KANtFWxqmTlQBYW-5WstWd7ewyrIaGDgZRLmjgw_3rpAT-7JKIpEXiWTAmJU2Hs4gcfXtQ7O3oSW_FHdJ31_3tTfYAkHj5i1TkfNoJpA-OWWCQbnvlat9If9_ZdL8hcVphje0-eMXZZf8WfIKmoCa0OwsW5gAs6vuE6zfs8LY_9G4yTZsarvwQPBceVdyIso4OAXV6u8CmX_K-MKSd6106w_8X1hLzdZKgDYnAOTnYxzlW7si-6DDC6PxVpbtT90dQKpH2ogACSS5_hBKuxARy80XXVclTFMVYBSpjNc9_tIETVd6Mr_NVCA9yhoZE9_dIwnZnevlYU-sxzDj_WZvegh1rGuhF3-LK-0u1TQysFjOfl1DTLDR32GYcNSMS_JYz7DbrB6HXDioqATq1R-p-If3KnFeUfcd_GA2-4A6FY

