# ============================================================================
# STACK: Actual Budget - Orçamento Pessoal
# VERSÃO: 1.2
# ============================================================================
#
# INSTRUÇÕES:
#   1. Copie este arquivo para actual.env
#   2. Preencha todas as variáveis marcadas com <ALTERAR>
#   3. Execute: docker stack deploy -c docker-compose.yaml ${STACK_PREFIX} --env-file actual.env
#
# ============================================================================

# ===== STACK =====
# Nome EXATO da stack no Swarm (usado no DNS interno dos servicos).
# Exemplo: se voce faz `docker stack deploy ... actual_budget`, use:
STACK_PREFIX=actual_budget

# ============================================================================
# ACTUAL BUDGET - Orçamento Pessoal
# https://actualbudget.org/docs/
# ============================================================================

# Porta exposta (0.0.0.0:PORTA)
ACTUAL_PORT=5006

# Senha do servidor Actual (definida no primeiro acesso ao Actual Budget)
ACTUAL_PASSWORD=<ALTERAR-senha-actual-server>

# ============================================================================
# ACTUAL HTTP API - REST API para integração com N8N
# https://github.com/jhonderson/actual-http-api
# ============================================================================

# Porta da API REST
ACTUAL_API_PORT=5007

# Chave de autenticação da API (usada no header: x-api-key)
ACTUAL_API_KEY=<ALTERAR-chave-api>

# Sync ID do orçamento (fixo — não muda)
# Defina o valor real no arquivo privado `actual.env`, ignorado pelo Git.
ACTUAL_BUDGET_SYNC_ID=<ALTERAR-budget-sync-id>

# ============================================================================
# ACTUAL AI - Classificação automática com LLM
# https://github.com/sakowicz/actual-ai
# ============================================================================

# Imagem do worker. Altere se quiser fixar versão/tag específica.
ACTUAL_AI_IMAGE=docker.io/sakowicz/actual-ai:latest

# Segurança operacional:
# Por padrão o FEATURES abaixo inclui "dryRun" para apenas sugerir/logar mudanças.
# Remova "dryRun" quando quiser permitir escrita efetiva no orçamento.
# `syncAccountsBeforeClassify` fica fora do default: ele roda o bank sync do
# Actual antes de classificar e pode importar/expor duplicatas vindas da
# integração bancária.
ACTUAL_AI_FEATURES=["dryRun","classifyOnStartup","rerunMissedTransactions","freeWebSearch"]

# Agenda padrão: roda a classificação a cada 6 horas.
ACTUAL_AI_CLASSIFICATION_SCHEDULE_CRON=0 */6 * * *

# Provedor LLM. Ajuste conforme o backend escolhido.
ACTUAL_AI_LLM_PROVIDER=openai

# OpenAI / OpenAI-compatible (OpenAI, OpenRouter compat, Ollama proxy, etc.)
ACTUAL_AI_OPENAI_API_KEY=
ACTUAL_AI_OPENAI_MODEL=gpt-4o-mini
ACTUAL_AI_OPENAI_BASE_URL=

# Anthropic
ACTUAL_AI_ANTHROPIC_API_KEY=
ACTUAL_AI_ANTHROPIC_MODEL=
ACTUAL_AI_ANTHROPIC_BASE_URL=

# Groq
ACTUAL_AI_GROQ_API_KEY=
ACTUAL_AI_GROQ_MODEL=
ACTUAL_AI_GROQ_BASE_URL=

# OpenRouter
ACTUAL_AI_OPENROUTER_API_KEY=
ACTUAL_AI_OPENROUTER_MODEL=
ACTUAL_AI_OPENROUTER_BASE_URL=
ACTUAL_AI_OPENROUTER_REFERRER=
ACTUAL_AI_OPENROUTER_TITLE=actual-ai
ACTUAL_AI_OPENROUTER_ENABLE_TOOL_CALLING=false

# Google Gemini
ACTUAL_AI_GOOGLE_GENERATIVE_AI_API_KEY=
ACTUAL_AI_GOOGLE_GENERATIVE_AI_MODEL=
ACTUAL_AI_GOOGLE_GENERATIVE_AI_BASE_URL=

# Ollama
ACTUAL_AI_OLLAMA_MODEL=
ACTUAL_AI_OLLAMA_BASE_URL=

# Recursos opcionais
# O prompt Sardinha fica versionado diretamente no docker-compose.yaml para manter o comportamento alinhado no deploy.
ACTUAL_AI_VALUESERP_API_KEY=
ACTUAL_AI_ACTUAL_E2E_PASSWORD=
ACTUAL_AI_NODE_TLS_REJECT_UNAUTHORIZED=
# Tags sugeridas para revisão humana das classificações.
ACTUAL_AI_NOT_GUESSED_TAG=#sardinha-revisar
ACTUAL_AI_GUESSED_TAG=#sardinha-ai
ACTUAL_AI_REQUESTS_PER_MINUTE=
ACTUAL_AI_TOKENS_PER_MINUTE=

# ============================================================================
# ACTUAL BI (PostgreSQL + worker de upsert conservador)
# ============================================================================

# Imagens
ACTUAL_BI_POSTGRES_IMAGE=postgres:16-alpine
ACTUAL_MCP_IMAGE=sstefanov/actual-mcp:latest

# PostgreSQL de BI (conexao direta por ferramentas externas)
ACTUAL_BI_POSTGRES_PORT=55432
ACTUAL_BI_DB_NAME=actual_bi
ACTUAL_BI_DB_USER=actual_bi
ACTUAL_BI_DB_PASSWORD=<ALTERAR-senha-forte>
ACTUAL_BI_DB_SSLMODE=disable
ACTUAL_BI_DB_CONNECT_TIMEOUT_SECONDS=10
ACTUAL_BI_POSTGRES_DATA_VOLUME_NAME=actual_bi_postgres_data

# Usuario read-only opcional (recomendado para Metabase/BI)
ACTUAL_BI_READONLY_DB_USER=actual_bi_ro
ACTUAL_BI_READONLY_DB_PASSWORD=<ALTERAR-senha-readonly>

# Origem do worker: actual-http-api desta mesma stack
# Opcional para execução manual do worker fora da rede do compose.
# Dentro da stack, o serviço usa por padrão `http://api:5007/v1`.
ACTUAL_HTTP_API_BASE_URL=
ACTUAL_HTTP_TIMEOUT_SECONDS=30
ACTUAL_HTTP_VERIFY_SSL=true
ACTUAL_HTTP_RETRIES=3
ACTUAL_HTTP_BACKOFF_SECONDS=2

# Escopo de ingestao (inclui categorygroups e schedules para dimensões de planejamento)
ACTUAL_BI_ENDPOINTS=accounts,transactions,payees,categories,categorygroups,schedules
# Janela para endpoint de transacoes por conta (since_date é obrigatório na API)
ACTUAL_BI_TRANSACTIONS_SINCE_DATE=2000-01-01
# Opcional. Vazio = sem filtro superior.
ACTUAL_BI_TRANSACTIONS_UNTIL_DATE=
ACTUAL_BI_REQUIRE_NON_EMPTY_BUDGETS=true
ACTUAL_BI_FAIL_ON_ENDPOINT_ERROR=true

# Worker
ACTUAL_BI_SYNC_INTERVAL_SECONDS=300
ACTUAL_BI_SYNC_RUN_ONCE=false
ACTUAL_BI_SYNC_LOG_LEVEL=INFO

# ============================================================================
# ACTUAL MCP - Model Context Protocol Server (SSE)
# ============================================================================

# Porta do servidor MCP
ACTUAL_MCP_PORT=3001

# O token de autorização do MCP está reutilizando a variável ACTUAL_API_KEY (Bearer Token)

# ============================================================================
# PLUGGY MCP - Open Finance / Dados Bancários
# ============================================================================

# Pluggy MCP (SSE — endpoint: /sse)
PLUGGY_MCP_PORT=3002

# API key da Pluggy usada pelo MCP para autenticar as chamadas na API.
# Gere em https://dashboard.pluggy.ai ou via endpoint /auth da propria Pluggy.
PLUGGY_API_KEY=

# Opcional: mantenha para referencia operacional ou para gerar nova API key.
# Obtenha em: https://dashboard.pluggy.ai > Aplicações > sua app > Client ID / Secret
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# ============================================================================
# ENDPOINTS (após deploy)
# ============================================================================
#
# Actual Budget:   http://localhost:5006
# Actual HTTP API: http://localhost:5007
# Actual MCP SSE:  http://localhost:3001
# Pluggy MCP SSE:  http://localhost:3002/sse
# BI Postgres:     host do manager : ${ACTUAL_BI_POSTGRES_PORT}
# Actual AI:       worker interno (sem porta pública)
#
# ============================================================================
# INTEGRAÇÃO VIA N8N
# ============================================================================
#
# Actual HTTP API (REST) - ACESSO INTERNO:
#   - Documentação: https://github.com/jhonderson/actual-http-api
#   - Base URL no N8N: http://SEU-HOST:5007
#   - Alternativa em Docker Desktop: http://host.docker.internal:5007
#   - API REST completa para orçamentos, contas e transações
#
# ============================================================================
# DEPLOY
# ============================================================================
# 1. Copie para actual.env e preencha os segredos e IDs privados
# 2. As imagens autorais `actual-bi-sync` e `pluggy-mcp` são publicadas via GitHub Actions no GHCR.
# 3. A imagem do Actual AI vem do Docker Hub por padrão; se o ambiente não tiver acesso, espelhe a imagem antes.
# 4. Deploy unificado (app + api + actual_ai + bi-postgres + bi-sync + actual_mcp + pluggy_mcp):
#      docker stack deploy -c docker-compose.yaml ${STACK_PREFIX} --env-file actual.env
# 5. Se voce ja tinha a stack separada "actual-bi", remova para evitar double-ingest:
#      docker stack rm actual-bi
# ============================================================================
