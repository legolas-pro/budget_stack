# ============================================================================
# TRAEFIK - Variaveis de Ambiente
# Copie este arquivo para .env e ajuste os valores para cada maquina
# ============================================================================

# ===== IMAGEM =====
TRAEFIK_IMAGE=traefik:v3.3

# ===== CERTIFICADOS (Let's Encrypt) =====
ACME_EMAIL=legolas@dinamopro.com

# ===== LOGS =====
# Niveis: DEBUG, INFO, WARN, ERROR
TRAEFIK_LOG_LEVEL=WARN
TRAEFIK_ACCESS_LOG=false

# ===== DASHBOARD =====
# Habilitar a API do dashboard internamente
TRAEFIK_DASHBOARD_ENABLED=true
# Expor o dashboard via Traefik (com dominio e TLS)
TRAEFIK_DASHBOARD_EXPOSE=false
TRAEFIK_DASHBOARD_HOST=traefik.dinamopro.com

# ===== RECURSOS =====
TRAEFIK_CPU_LIMIT=1.0
TRAEFIK_MEM_LIMIT=512M
TRAEFIK_CPU_RESERVATION=0.25
TRAEFIK_MEM_RESERVATION=128M
